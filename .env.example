# ==== King Street — Configuração de Ambiente ====
# Copie este arquivo para ".env" e ajuste os valores.

# Segurança
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Loja
STORE_NAME=King Street
# Número do WhatsApp da loja (somente dígitos, com DDI+DDD). Ex: 5511999999999
STORE_WHATSAPP=5511999999999

# Painel administrativo
# Usados pelo comando "python manage.py criar_admin" (roda a cada deploy).
ADMIN_USERNAME=emerson
ADMIN_PASSWORD=emer123
ADMIN_EMAIL=emerson@kingstreet.local

# Banco de dados
# 1) Railway/produção: o plugin PostgreSQL injeta DATABASE_URL sozinho,
#    e ela tem prioridade sobre tudo que vem abaixo.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# 2) PostgreSQL local: preencha DB_ENGINE e os campos abaixo.
# 3) Deixe tudo vazio para usar SQLite no desenvolvimento.
DB_ENGINE=
DB_NAME=kingstreet
DB_USER=kingstreet
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
