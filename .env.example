# ==== King Street — Configuração de Ambiente ====
# Copie este arquivo para ".env" e ajuste os valores.

# Segurança
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Loja
STORE_NAME=King Street
# Número do WhatsApp da loja (somente dígitos, com DDI+DDD). Ex: 5511999999999
STORE_WHATSAPP=5511999999999

# Banco de dados
# Deixe DB_ENGINE vazio para usar SQLite no desenvolvimento.
# Para PostgreSQL (produção), preencha os campos abaixo:
DB_ENGINE=
DB_NAME=kingstreet
DB_USER=kingstreet
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
